rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Solo usuarios autenticados (la app inicia sesión anónima automáticamente)
    // pueden leer y escribir traslados. Esto evita que cualquier persona en
    // internet que no haya abierto la app pueda leer/editar tus datos.
    match /traslados/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
